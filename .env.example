# === Gemini (required by the analyze server) ===
GEMINI_API_KEY=your_key_here
# Current multimodal models (June 2026): gemini-2.5-flash, gemini-2.5-flash-lite, gemini-3.5-flash
GEMINI_MODEL=gemini-2.5-flash

# === Flask server ===
FLASK_PORT=5000

# === Offline demo: 1 = canned results, no Gemini call/credits needed; 0 = real Gemini ===
GEMINI_MOCK=0

# === Candidate generation -> Gemini verification ===
# color  = OpenCV color-segmentation candidate proposer (recall-oriented)  [default]
# opencv = OpenCV geometric (Hough/contour) cell detector
# gemini = Gemini detects + verifies in one pass (no OpenCV stage)
DETECTOR=color

# Filter: drop candidates with confidence below this (0..1). exists=false is always dropped.
CONFIDENCE_THRESHOLD=0.7

# Max candidates considered per image
MAX_CELLS=24

# === Gemini batching (stability) ===
# Crops are split into batches of this many before each Gemini call (~32-48 safe).
GEMINI_BATCH_SIZE=48

# === RAG reference gallery (classification calibration) ===
# Folder of curated ideal-young-larva crops (rag*.jpg/png) prepended to every
# Gemini batch as few-shot exemplars. Leave default unless you move the folder.
GEMINI_REFERENCE_DIR=web/sample_images/rag
